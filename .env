# ─── Food Delivery System — Environment Variables ───────────────────────────
# Database (SQLite is used by default — zero setup required)
# For PostgreSQL: postgresql://user:password@localhost:5432/fooddelivery
DATABASE_URL=sqlite:///./fooddelivery.db

# App secret key (change this in production!)
SECRET_KEY=change-this-secret-key-in-production

# Stripe (optional — mock gateway is used if not set)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Environment
ENVIRONMENT=development
